{
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3.0.24"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/((?!api/|assets/|images/|favicon\\.ico|favicon\\.png|placeholder\\.svg|robots\\.txt|presentation\\.html).*)",
      "destination": "/index.html"
    }
  ]
}
