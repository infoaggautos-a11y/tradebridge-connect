# Environment Variables
# Copy this file to .env and fill in your actual values

# ===================
# APP CONFIG
# ===================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ===================
# DATABASE
# ===================
DATABASE_URL=postgresql://user:password@localhost:5432/dil_trade_bridge

# ===================
# JWT SECRET
# ===================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===================
# STRIPE CONFIG
# ===================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_CONNECT_CLIENT_ID=ca_your_stripe_connect_client_id
STRIPE_PRO_PRODUCT_ID=prod_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx
STRIPE_BUSINESS_PRODUCT_ID=prod_xxx
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_xxx
STRIPE_BUSINESS_ANNUAL_PRICE_ID=price_xxx

# ===================
# PAYSTACK CONFIG
# ===================
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ===================
# WISE (TRANSFERWISE) CONFIG
# ===================
WISE_API_KEY=your_wise_api_key
WISE_ACCOUNT_ID=your_wise_account_id

# ===================
# EMAIL (SENDGRID)
# ===================
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@diltradebridge.com
EMAIL_FROM_NAME=DIL Trade Bridge

# ===================
# SMS (TWILIO)
# ===================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ===================
# KYC PROVIDERS
# ===================
SMILE_IDENTITY_APP_ID=your_smile_identity_app_id
SMILE_IDENTITY_API_KEY=your_smile_identity_api_key
SUMSUB_APP_TOKEN=your_sumsub_app_token
SUMSUB_SECRET_KEY=your_sumsub_secret_key

# ===================
# AML PROVIDERS
# ===================
COMPLYADVANTAGE_API_KEY=your_complyadvantage_api_key

# ===================
# COMPANY BANK ACCOUNT (For Payouts)
# ===================
