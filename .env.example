# Environment template for local development
# Copy to `.env` for the frontend and serverless/API runtimes that read from process.env.
# Do not expose server-only secrets in client code.

# ===================
# Frontend (Vite)
# Exposed to the browser via import.meta.env
# ===================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_API_URL=http://localhost:3001
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
VITE_STRIPE_STARTER_PRODUCT_ID=prod_your_starter_product
VITE_STRIPE_STARTER_MONTHLY_PRICE_ID=price_your_starter_monthly
VITE_STRIPE_STARTER_ANNUAL_PRICE_ID=price_your_starter_annual
VITE_STRIPE_GROWTH_PRODUCT_ID=prod_your_growth_product
VITE_STRIPE_GROWTH_MONTHLY_PRICE_ID=price_your_growth_monthly
VITE_STRIPE_GROWTH_ANNUAL_PRICE_ID=price_your_growth_annual

# ===================
# Server / Node runtime
# Used by /server and legacy Node-based services
# ===================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
LOG_LEVEL=debug
COMPANY_REG_NUMBER=your_company_registration_number

# ===================
# Supabase secrets
# Server-side only. Never expose these to the browser.
# ===================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===================
# Stripe
# Used by API routes, server routes, and Supabase functions
# ===================
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_STARTER_PRODUCT_ID=prod_your_starter_product
STRIPE_STARTER_MONTHLY_PRICE_ID=price_your_starter_monthly
STRIPE_STARTER_ANNUAL_PRICE_ID=price_your_starter_annual
STRIPE_GROWTH_PRODUCT_ID=prod_your_growth_product
STRIPE_GROWTH_MONTHLY_PRICE_ID=price_your_growth_monthly
STRIPE_GROWTH_ANNUAL_PRICE_ID=price_your_growth_annual

# ===================
# Additional payment provider
# Used by server payout and payment routes
# ===================
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
